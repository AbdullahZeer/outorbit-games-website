---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Logo from '../components/Logo.astro';
import { Mail } from 'lucide-astro';
import XIcon from '../components/icons/XIcon.astro';
import TikTokIcon from '../components/icons/TikTokIcon.astro';
import YoutubeIcon from '../components/icons/YoutubeIcon.astro';

const title = "Outorbit — Exploring Beyond Orbit";
const description = "Outorbit is an independent studio exploring beyond orbit. We refine genres, push their limits, and find quiet innovation within familiar forms.";
---

<Layout title={title} description={description}>
	<Starfield />
	
	<main class="relative min-h-screen flex flex-col items-center justify-center px-4 py-16">
		<!-- Logo Header -->
		<div class="mb-12 animate-fade-in">
			<Logo />
		</div>

		<!-- Main Content Card -->
		<div class="w-full max-w-[65ch] backdrop-blur-md bg-white/5 border border-white/10 rounded-lg p-8 md:p-12 shadow-2xl animate-fade-in-delay">
			<!-- Studio Name -->
			<h1 class="text-3xl md:text-4xl font-light mb-6 text-center tracking-wide">
				Outorbit
			</h1>

			<!-- Title/Tagline -->
			<p class="text-lg md:text-xl text-gray-300 text-center mb-6 leading-relaxed">
				Outorbit is an independent studio exploring beyond orbit.
			</p>

			<!-- Studio Philosophy -->
			<div class="text-base md:text-lg text-gray-300 text-center mb-8 leading-relaxed max-w-[65ch] mx-auto">
				<p class="mb-2">
					At Outorbit, we don't aim to invent new genres. We refine them.
				</p>
				<p>
					We believe innovation happens when we stay close to what feels familiar and push it just far enough to feel new again.
				</p>
			</div>

			<!-- Status Line -->
			<p class="text-base md:text-lg text-gray-400 text-center mb-10 italic">
				Quietly working on our first game.
			</p>

			<!-- Contact -->
			<div class="text-center mb-10">
				<a
					href="mailto:contact@outorbit.games"
					class="inline-flex items-center gap-2 text-white hover:text-[#B0F0FF] transition-colors duration-300 underline decoration-white/30 hover:decoration-[#B0F0FF]/50 underline-offset-4"
				>
					<Mail class="w-4 h-4" />
					contact@outorbit.games
				</a>
			</div>

			<!-- Social Links -->
			<div class="flex justify-center gap-6 flex-wrap">
				<a
					href="https://twitter.com/outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300"
					aria-label="X (Twitter)"
				>
					<XIcon class="w-5 h-5" />
				</a>
				<a
					href="https://tiktok.com/@outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300"
					aria-label="TikTok"
				>
					<TikTokIcon class="w-5 h-5" />
				</a>
				<a
					href="https://youtube.com/@outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300"
					aria-label="YouTube"
				>
					<YoutubeIcon class="w-5 h-5" />
				</a>
			</div>
		</div>

		<!-- Footer -->
		<footer class="mt-16 text-center text-gray-500 text-sm animate-fade-in-delay-2">
			<p>© Outorbit • All Rights Reserved</p>
		</footer>
	</main>
</Layout>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 1.5s ease-in-out;
	}

	.animate-fade-in-delay {
		animation: fade-in 1.5s ease-in-out 0.3s both;
	}

	.animate-fade-in-delay-2 {
		animation: fade-in 1.5s ease-in-out 0.6s both;
	}
</style>

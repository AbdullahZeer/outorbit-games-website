---
import Layout from '../layouts/Layout.astro';
import Starfield from '../components/Starfield.astro';
import Logo from '../components/Logo.astro';

const title = "Outorbit Games — Exploring Beyond Orbit";
const description = "Outorbit Games is an independent game studio exploring atmospheric, story-driven worlds beyond orbit.";
---

<Layout title={title} description={description}>
	<Starfield />
	
	<main class="relative min-h-screen flex flex-col items-center justify-center px-4 py-16">
		<!-- Logo Header -->
		<div class="mb-12 animate-fade-in">
			<Logo />
		</div>

		<!-- Main Content Card -->
		<div class="w-full max-w-[700px] backdrop-blur-md bg-white/5 border border-white/10 rounded-lg p-8 md:p-12 shadow-2xl animate-fade-in-delay">
			<!-- Studio Name -->
			<h1 class="text-3xl md:text-4xl font-light mb-6 text-center tracking-wide">
				Outorbit Games
			</h1>

			<!-- Tagline -->
			<p class="text-lg md:text-xl text-gray-300 text-center mb-8 leading-relaxed">
				Independent game studio exploring beyond orbit.
			</p>

			<!-- Status Line -->
			<p class="text-base md:text-lg text-gray-400 text-center mb-10 italic">
				Quietly working on our first game.
			</p>

			<!-- Contact -->
			<div class="text-center mb-10">
				<a
					href="mailto:hello@outorbit.games"
					class="inline-block text-white hover:text-[#B0F0FF] transition-colors duration-300 underline decoration-white/30 hover:decoration-[#B0F0FF]/50 underline-offset-4"
				>
					hello@outorbit.games
				</a>
			</div>

			<!-- Social Links -->
			<div class="flex justify-center gap-6 flex-wrap">
				<a
					href="https://twitter.com/outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300 text-sm"
					aria-label="Twitter"
				>
					Twitter
				</a>
				<span class="text-gray-600">•</span>
				<a
					href="https://outorbitgames.itch.io"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300 text-sm"
					aria-label="Itch.io"
				>
					Itch.io
				</a>
				<span class="text-gray-600">•</span>
				<a
					href="https://youtube.com/@outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300 text-sm"
					aria-label="YouTube"
				>
					YouTube
				</a>
				<span class="text-gray-600">•</span>
				<a
					href="https://discord.gg/outorbitgames"
					target="_blank"
					rel="noopener noreferrer"
					class="text-gray-400 hover:text-white transition-colors duration-300 text-sm"
					aria-label="Discord"
				>
					Discord
				</a>
			</div>
		</div>

		<!-- Footer -->
		<footer class="mt-16 text-center text-gray-500 text-sm animate-fade-in-delay-2">
			<p>© Outorbit Games • All Rights Reserved</p>
		</footer>
	</main>
</Layout>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-fade-in {
		animation: fade-in 1.5s ease-in-out;
	}

	.animate-fade-in-delay {
		animation: fade-in 1.5s ease-in-out 0.3s both;
	}

	.animate-fade-in-delay-2 {
		animation: fade-in 1.5s ease-in-out 0.6s both;
	}
</style>

---
// Outorbit logo - "OO" monogram with orbits and breaking free concept
---

<svg
	width="120"
	height="120"
	viewBox="0 0 120 120"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	class="w-24 h-24 md:w-32 md:h-32"
	aria-label="Outorbit Games Logo"
>
	<!-- Outer orbit -->
	<circle
		cx="60"
		cy="60"
		r="45"
		stroke="white"
		stroke-width="1.5"
		opacity="0.6"
		fill="none"
	/>
	
	<!-- Inner orbit -->
	<circle
		cx="60"
		cy="60"
		r="30"
		stroke="white"
		stroke-width="1.5"
		opacity="0.6"
		fill="none"
	/>
	
	<!-- Breaking free arrow/rocket -->
	<path
		d="M 75 45 L 85 50 L 80 55 L 75 50 Z"
		fill="white"
		opacity="0.9"
	/>
	<line
		x1="75"
		y1="45"
		x2="90"
		y2="40"
		stroke="white"
		stroke-width="1.5"
		opacity="0.7"
	/>
</svg>

